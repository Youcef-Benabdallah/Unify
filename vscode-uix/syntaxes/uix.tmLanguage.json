{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "UIX",
  "scopeName": "source.uix",
  "fileTypes": ["uix"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#component-tag" },
    { "include": "#attribute" },
    { "include": "#meta-block" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.uix"
        },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.uix"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.uix",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.uix"
        }
      ]
    },
    "component-tag": {
      "match": "\\b[A-Z][a-zA-Z0-9]*\\b",
      "name": "entity.name.tag.uix"
    },
    "attribute": {
      "match": "([a-zA-Z_][a-zA-Z0-9_-]*)\\s*:",
      "captures": {
        "1": { "name": "variable.other.property.uix" }
      }
    },
    "meta-block": {
      "match": "\\b(Meta|App|Page|Section|Layout)\\b",
      "name": "keyword.control.uix"
    },
    "punctuation": {
      "patterns": [
        { "match": "\\{", "name": "punctuation.definition.brace.curly.begin.uix" },
        { "match": "\\}", "name": "punctuation.definition.brace.curly.end.uix" },
        { "match": ";", "name": "punctuation.separator.uix" }
      ]
    }
  }
}
