// pages/index.uix — Dashboard Overview
Meta { title: "Overview | Dashboard" }

Page {
  // Stats cards
  Grid {
    Card {
      className: "text-center"
      Header { text: "1,247" }
      Text { className: "brut-text--muted"; content: "Total Users" }
    }

    Card {
      className: "text-center"
      Header { text: "$84.2K" }
      Text { className: "brut-text--muted"; content: "Revenue" }
    }

    Card {
      className: "text-center"
      Header { text: "98.5%" }
      Text { className: "brut-text--muted"; content: "Uptime" }
    }

    Card {
      className: "text-center"
      Header { text: "12" }
      Text { className: "brut-text--muted"; content: "Active Projects" }
    }
  }

  // Activity section
  Section {
    H2 { text: "Recent Activity" }

    Card {
      className: "brut-flex-between"
      Text { content: "New user signed up" }
      Badge { variant: success; text: "Done" }
    }

    Card {
      className: "brut-flex-between"
      Text { content: "Server deployment completed" }
      Badge { variant: info; text: "Live" }
    }

    Card {
      className: "brut-flex-between"
      Text { content: "Payment received — $2,400" }
      Badge { variant: success; text: "Paid" }
    }

    Card {
      className: "brut-flex-between"
      Text { content: "Database backup finished" }
      Badge { variant: warning; text: "Running" }
    }
  }
}
