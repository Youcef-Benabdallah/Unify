{
  "name": "unify",
  "version": "0.6.7",
  "description": "Static site framework with .uix components, neu-brutalism design, Lucide icons, reactive state, and SPA routing",
  "main": "src/index.js",
  "bin": {
    "unify": "./bin/unify.js"
  },
  "scripts": {
    "dev": "node bin/unify.js dev",
    "build": "node bin/unify.js build",
    "start": "node bin/unify.js start"
  },
  "author": "Youcef Benabdallah",
  "license": "MIT",
  "keywords": [
    "unify", "uix", "static-site", "framework", "brutalism", "neu-brutalism",
    "ssg", "spa", "reactive", "file-based-routing", "lucide", "no-build-step"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Youcef-Benabdallah/unify"
  },
  "files": [
    "bin/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "ws": "^8.16.0"
  },
  "optionalDependencies": {
    "typescript": "^5.4.0"
  }
}
